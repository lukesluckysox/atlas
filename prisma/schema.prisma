generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  username     String?      @unique
  passwordHash String?
  name         String?
  image        String?
  isPro        Boolean      @default(false)
  stripeId     String?
  createdAt    DateTime     @default(now())
  pairings     Pairing[]
  experiences  Experience[]
  encounters   Encounter[]
  marks        Mark[]
  roads        HighwayStretch[]
  portrait     Portrait?
  accounts     Account[]
  sessions     Session[]
  spotifyLink  SpotifyLink?
  collections  Collection[]
}

// A user-curated set of traces. Fully manual. Pro-only surface
// (gating enforced in the API, not the schema).
model Collection {
  id          String           @id @default(cuid())
  userId      String
  title       String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionItem[]

  @@index([userId, updatedAt])
}

// Polymorphic membership: a collection item references one trace of a given
// kind. kind ∈ {"tracks","path","notice","encounter"}. refId is the target
// row's id. No FK — soft references so deleting a trace doesn't cascade
// awkwardly; dangling items are filtered at read time.
model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  kind         String
  refId        String
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, kind, refId])
  @@index([collectionId, addedAt])
}

model SpotifyLink {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  spotifyId     String?
  displayName   String?
  refreshToken  String   @db.Text
  accessToken   String   @db.Text
  expiresAt     DateTime
  scope         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Pairing {
  id               String   @id @default(cuid())
  userId           String
  photoUrl         String
  spotifyTrackId   String
  trackName        String
  artistName       String
  albumArt         String?
  genres           String[] @default([])
  note             String?
  caption          String?
  captionDismissed Boolean  @default(false)
  location         String?
  latitude         Float?
  longitude        Float?
  photoLum         Float?
  photoWarmth      Float?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
}

model Experience {
  id          String    @id @default(cuid())
  userId      String
  type        String
  name        String
  location    String?
  latitude    Float?
  longitude   Float?
  date        DateTime?
  note        String?
  photoUrl    String?
  photoLum    Float?
  photoWarmth Float?
  boundary    Json?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}

model Encounter {
  id          String   @id @default(cuid())
  userId      String
  question    String
  answer      String?  @db.Text
  landed      Boolean?
  // True when the user explicitly chose to sit with the question rather than
  // marking it landed/didn't-land. Distinct from landed=null (unanswered).
  sittingWith Boolean  @default(false)
  // Optional pointer to a past encounter whose question this one echoes.
  // Set once on creation by the AI; stable thereafter. Not a FK — soft ref
  // so deletes don't cascade.
  echoOfId    String?
  date        DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Portrait {
  id              String   @id @default(cuid())
  userId          String   @unique
  summary         String   @db.Text
  tasteProfile    Json
  movementProfile Json
  questionProfile Json
  markProfile     Json?
  generatedAt     DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model Mark {
  id          String   @id @default(cuid())
  userId      String
  content     String
  summary     String?
  keyword     String?
  photoUrl    String?
  latitude    Float?
  longitude   Float?
  photoLum    Float?
  photoWarmth Float?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model HighwayStretch {
  id          String    @id @default(cuid())
  userId      String
  name        String
  ref         String?
  category    String?
  startLabel  String
  endLabel    String
  startLat    Float
  startLng    Float
  endLat      Float
  endLng      Float
  geometry    Json
  distanceMi  Float
  drivenAt    DateTime?
  drivenNote  String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
