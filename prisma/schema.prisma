generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  username     String?      @unique
  passwordHash String?
  name         String?
  image        String?
  isPro        Boolean      @default(false)
  stripeId     String?
  createdAt    DateTime     @default(now())
  pairings     Pairing[]
  experiences  Experience[]
  encounters   Encounter[]
  marks        Mark[]
  roads        HighwayStretch[]
  portrait     Portrait?
  accounts     Account[]
  sessions     Session[]
  spotifyLink  SpotifyLink?
}

model SpotifyLink {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  spotifyId     String?
  displayName   String?
  refreshToken  String   @db.Text
  accessToken   String   @db.Text
  expiresAt     DateTime
  scope         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Pairing {
  id             String   @id @default(cuid())
  userId         String
  photoUrl       String
  spotifyTrackId String
  trackName      String
  artistName     String
  albumArt       String?
  note           String?
  location       String?
  latitude       Float?
  longitude      Float?
  photoLum       Float?
  photoWarmth    Float?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
}

model Experience {
  id          String    @id @default(cuid())
  userId      String
  type        String
  name        String
  location    String?
  latitude    Float?
  longitude   Float?
  date        DateTime?
  note        String?
  photoUrl    String?
  photoLum    Float?
  photoWarmth Float?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}

model Encounter {
  id       String   @id @default(cuid())
  userId   String
  question String
  answer   String?  @db.Text
  landed   Boolean?
  date     DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
}

model Portrait {
  id              String   @id @default(cuid())
  userId          String   @unique
  summary         String   @db.Text
  tasteProfile    Json
  movementProfile Json
  questionProfile Json
  markProfile     Json?
  generatedAt     DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model Mark {
  id          String   @id @default(cuid())
  userId      String
  content     String
  photoUrl    String?
  latitude    Float?
  longitude   Float?
  photoLum    Float?
  photoWarmth Float?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model HighwayStretch {
  id          String    @id @default(cuid())
  userId      String
  name        String
  ref         String?
  category    String?
  startLabel  String
  endLabel    String
  startLat    Float
  startLng    Float
  endLat      Float
  endLng      Float
  geometry    Json
  distanceMi  Float
  drivenAt    DateTime?
  drivenNote  String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
